---
import { themeConfig } from '@/theme.config'
import { SEO } from 'astro-seo'

interface Props {
  title?: string
  description?: string
  openGraph?: unknown
  twitter?: unknown
}

const { title = themeConfig.site.title, description = themeConfig.site.description } = Astro.props
---

<SEO title={title} description={description} />
