---
import { ClientRouter } from 'astro:transitions'
import SiteCredits from '@/components/SiteCredits.astro'
import SiteNavigation from '@/components/SiteNavigation.astro'
import SiteSocial from '@/components/SiteSocial.astro'
import SiteTitle from '@/components/SiteTitle.astro'
import { themeConfig } from '@/theme.config'
import '@/styles/main.css'
---

<html lang={themeConfig.site.locale}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Astro</title>
    <ClientRouter />
  </head>
  <body>
    <div class="container mx-auto lg:flex lg:flex-row-reverse">
      <header class="p-7.5 flex flex-col gap-2.5 relative">
        <SiteTitle />
        <nav class="flex flex-col gap-3.5">
          <SiteNavigation />
          <SiteSocial />
        </nav>
        <SiteCredits class:list={['lg:block hidden']} />
      </header>

      <main transition:animate="fade" class="lg:grow px-7.5">
        <slot />
      </main>

      <footer class="lg:hidden p-7.5">
        <SiteCredits />
      </footer>
    </div>
  </body>
</html>
