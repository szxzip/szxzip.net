---
import { ClientRouter } from 'astro:transitions'
import SiteCredits from '@/components/SiteCredits.astro'
import SiteNavigation from '@/components/SiteNavigation.astro'
import SiteSocial from '@/components/SiteSocial.astro'
import SiteTitle from '@/components/SiteTitle.astro'
import { themeConfig } from '@/theme.config'
import '@/styles/main.css'

const fadeDown = {
  forwards: {
    old: { name: 'fade-out-down', duration: '0.5s', easing: 'linear' },
    new: { name: 'fade-in-down', duration: '0.5s', easing: 'linear', delay: '0.5s' },
  },
  backwards: {
    old: { name: 'fade-out-down', duration: '0.5s', easing: 'linear' },
    new: { name: 'fade-in-down', duration: '0.5s', easing: 'linear', delay: '0.5s' },
  },
}
---

<html lang={themeConfig.site.locale}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Astro</title>
    <ClientRouter />
  </head>
  <body>
    <div class="container p-7.5" transition:animate={fadeDown}>
      <header class="m-7.5 flex flex-col gap-2.5" transition:persist>
        <SiteTitle />
        <nav class="flex flex-col gap-3.5">
          <SiteNavigation />
          <SiteSocial />
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="my-7.5">
        <SiteCredits />
      </footer>
    </div>
  </body>
</html>

<style is:inline>
  @keyframes fade-in-down {
    0% {
      transform: translateY(-1rem);
      opacity: 0;
    }
    100% {
      transform: translateY(0);
      opacity: 1;
    }
  }

  @keyframes fade-out-down {
    0% {
      transform: translateY(0);
      opacity: 1;
    }
    100% {
      transform: translateY(1rem);
      opacity: 0;
    }
  }

  @keyframes fade-in-left {
    0% {
      opacity: 0;
      transform: translateX(1rem);
    }
    100% {
      opacity: 1;
      transform: translateX(0);
    }
  }
</style>
